# Secrets
.env
.env.local
research-diary/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Virtualenvs
.venv/
venv/

# IDE
.vscode/
.idea/

# Strategies are generated artifacts (meta dirs kept explicitly via tracked content)
# Note: keep _drafts/, _trajectories/, _examples/, _iterate_context.md under strategies/
# but the strategy output dirs themselves are generated — handle explicitly if needed

# Reports + artifacts
*.log

# Large/regeneratable data — not suitable for git tracking
data/_archive/                  # archival legacy (KRX, etc.) — out of unified flow
data/binance_multi/1m/          # 1-minute bars — project does not consume
data/binance_lob/               # LOB snapshots — forward-going, multi-GB

# PDFs (use external links instead)
docs/*.pdf
literature/papers/*.pdf

# Paper-search scratch
papers/.project_analysis.json
deep/knowledge-graph.json

# Iteration outputs — generated per run (specs/code/results/traces/report.html, multi-GB)
# Each run produces ~80 specs × multiple artifacts. Recreatable from inputs.
iterations/
iterations_archive_*/
iterations_v3_archive/
iterations_v4_archive/
iterations_v5_archive_*/

# Per-run logs / lock files
.claude/scheduled_tasks.lock
*.output

# Per-run analysis figures (regeneratable from analysis/figures/gen_*.py)
analysis/figures/*.png

# wiki-sync generated index (regenerated from code by ResearchWiki tooling)
index/

# Old prior_iterations backups (kept locally only — historical, not paper-grade)
.claude/agents/chain1/signal-generator/references/prior_iterations_index.md.archive_*
.claude/agents/chain1/signal-generator/references/prior_iterations_index.md.v3v4_archive
