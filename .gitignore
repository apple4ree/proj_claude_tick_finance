# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Virtualenvs
.venv/
venv/

# IDE
.vscode/
.idea/

# Strategies are generated artifacts (meta dirs kept explicitly via tracked content)
# Note: keep _drafts/, _trajectories/, _examples/, _iterate_context.md under strategies/
# but the strategy output dirs themselves are generated — handle explicitly if needed

# Reports + artifacts
*.log

# Large/regeneratable data — not suitable for git tracking
data/_archive/                  # archival legacy (KRX, etc.) — out of unified flow
data/binance_multi/1m/          # 1-minute bars — project does not consume
data/binance_lob/               # LOB snapshots — forward-going, multi-GB

# PDFs (use external links instead)
docs/*.pdf
literature/papers/*.pdf

# Paper-search scratch
papers/.project_analysis.json
