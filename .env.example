# Chain 1 LLM configuration — copy to `.env` and fill in.
#
# .env is gitignored. NEVER commit a real API key.

# ---------------------------------------------------------------------------
# API keys (set only those you plan to use)
# ---------------------------------------------------------------------------

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-5, o3/o4 reasoning models)
OPENAI_API_KEY=sk-...

# Google Gemini (both Studio and Vertex can work; LiteLLM routes on model prefix)
GEMINI_API_KEY=...

# ---------------------------------------------------------------------------
# Default model + per-stage overrides
# ---------------------------------------------------------------------------
# Model strings follow LiteLLM conventions:
#   - "claude-opus-4-7"                 (Anthropic)
#   - "gpt-5" / "gpt-5-mini" / "o4-mini"      (OpenAI)
#   - "gemini/gemini-2.5-pro" / "gemini/gemini-2.5-flash"   (Google)

# Chain 1 default is Opus tier per CLAUDE.md (2026-04-20).
CHAIN1_DEFAULT_MODEL=claude-opus-4-7

# Per-agent overrides (empty = use CHAIN1_DEFAULT_MODEL)
# Mix-and-match providers freely — e.g., Opus for creative generation,
# a fast OpenAI model for mechanical evaluation.
CHAIN1_MODEL_SIGNAL_GENERATOR=
CHAIN1_MODEL_SIGNAL_EVALUATOR=
CHAIN1_MODEL_FEEDBACK_ANALYST=
CHAIN1_MODEL_SIGNAL_IMPROVER=

# ---------------------------------------------------------------------------
# Generation controls
# ---------------------------------------------------------------------------

# Max output tokens for structured responses
CHAIN1_MAX_OUTPUT_TOKENS=8000

# Reasoning / thinking budget.
#   - Anthropic Opus 4.7: 0 disables extended thinking; supports up to 32000.
#   - OpenAI o1/o3/o4: mapped to reasoning_effort=low (<=2000), medium (<=8000), high (>8000).
#   - Gemini 2.5 Thinking: mapped to reasoning_effort.
CHAIN1_THINKING_BUDGET=8000

# Timeout for a single LLM call (seconds)
CHAIN1_REQUEST_TIMEOUT_SEC=300

# Number of retry attempts on transient errors (rate limit / 5xx)
CHAIN1_MAX_RETRIES=2
